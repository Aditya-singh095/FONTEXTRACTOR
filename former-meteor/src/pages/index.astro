---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="grain-overlay"></div>
  
  <!-- Header -->
  <header class="site-header">
    <div class="container header-inner">
      <div class="logo animate-fade-up">
        <span class="logo-mark">F</span>
        <span class="logo-text">FontScan</span>
      </div>
      <nav class="nav-links animate-fade-up delay-1">
        <span class="tag">v1.0</span>
        <span class="tag">Browser-Only · No Uploads</span>
      </nav>
    </div>
  </header>

  <!-- Hero -->
  <section class="hero">
    <div class="glow-blob hero-blob-1"></div>
    <div class="glow-blob hero-blob-2"></div>
    <div class="container hero-content">
      <div class="hero-eyebrow animate-fade-up">
        <span class="eyebrow-line"></span>
        <span class="tag">OCR + Font Detection</span>
      </div>
      <h1 class="hero-title animate-fade-up delay-1">
        Read what the<br/>
        <em>eye can see.</em>
      </h1>
      <p class="hero-subtitle animate-fade-up delay-2">
        Drop an image. Get the text, get the font. 
        Entirely in your browser — zero server, zero tracking.
      </p>
    </div>
    <div class="hero-type-strip animate-fade-up delay-3">
      <div class="type-scroll-inner">
        <span>Aa Bb Cc Dd Ee Ff Gg Hh Ii Jj Kk Ll Mm Nn Oo Pp Qq Rr Ss Tt Uu Vv Ww Xx Yy Zz</span>
        <span aria-hidden="true">Aa Bb Cc Dd Ee Ff Gg Hh Ii Jj Kk Ll Mm Nn Oo Pp Qq Rr Ss Tt Uu Vv Ww Xx Yy Zz</span>
      </div>
    </div>
  </section>

  <!-- Main Extractor Tool -->
  <main id="tool" class="tool-section">
    <div class="container">
      <div class="tool-grid">

        <!-- Left: Input Panel -->
        <div class="panel input-panel animate-fade-up delay-2">
          <div class="panel-header">
            <h2 class="panel-title">Input</h2>
            <div class="panel-dots">
              <span></span><span></span><span></span>
            </div>
          </div>

          <!-- Upload Zone -->
          <div class="upload-zone" id="upload-zone">
            <div class="upload-icon">
              <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
                <path d="M20 8v16M13 15l7-7 7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M6 28v4a2 2 0 002 2h24a2 2 0 002-2v-4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>
            <p class="upload-label">Drop image here</p>
            <p class="upload-sub">PNG, JPG, WEBP, BMP, TIFF</p>
            <input type="file" id="file-input" accept="image/*" class="sr-only" />
            <button class="btn btn-ghost" id="browse-btn" type="button">Browse Files</button>
          </div>

          <div class="or-divider">
            <span class="divider"></span>
            <span class="or-label">or</span>
            <span class="divider"></span>
          </div>

          <!-- URL Input -->
          <div class="url-input-group">
            <label class="input-label" for="url-input">Image URL</label>
            <div class="url-row">
              <input
                type="url"
                id="url-input"
                class="input"
                placeholder="https://example.com/image.png"
              />
              <button class="btn btn-ghost" id="url-btn" type="button">Load</button>
            </div>
          </div>

          <!-- Preview -->
          <div class="preview-area" id="preview-area" style="display:none">
            <img id="preview-img" src="" alt="Preview" class="preview-img" />
            <button class="clear-btn" id="clear-btn" type="button" title="Clear image">✕</button>
          </div>

          <!-- Extract Button -->
          <button class="btn btn-primary extract-btn" id="extract-btn" disabled>
            <span class="btn-icon">◈</span>
            Extract Text &amp; Font
          </button>

          <!-- Progress -->
          <div class="progress-wrap" id="progress-wrap" style="display:none">
            <div class="progress-bar">
              <div class="progress-fill" id="progress-fill" style="width:0%"></div>
            </div>
            <span class="progress-label" id="progress-label">Initializing OCR engine…</span>
          </div>
        </div>

        <!-- Right: Results Panel -->
        <div class="panel results-panel animate-fade-up delay-3">
          <div class="panel-header">
            <h2 class="panel-title">Results</h2>
            <div class="panel-actions" id="panel-actions" style="display:none">
              <button class="btn btn-ghost btn-sm" id="copy-btn" type="button">Copy Text</button>
              <button class="btn btn-ghost btn-sm" id="download-btn" type="button">Download</button>
            </div>
          </div>

          <!-- Empty State -->
          <div class="empty-state" id="empty-state">
            <div class="empty-grid">
              <div class="empty-letter" style="--d:0">A</div>
              <div class="empty-letter" style="--d:1">a</div>
              <div class="empty-letter" style="--d:2">B</div>
              <div class="empty-letter" style="--d:3">b</div>
              <div class="empty-letter" style="--d:4">C</div>
              <div class="empty-letter" style="--d:5">c</div>
            </div>
            <p class="empty-label">Results appear here after extraction</p>
          </div>

          <!-- Results Content -->
          <div class="results-content" id="results-content" style="display:none">
            <!-- Font Info -->
            <div class="font-result-section">
              <h3 class="section-label">Detected Font Traits</h3>
              <div class="font-traits" id="font-traits"></div>
            </div>
            <div class="divider" style="margin-block:1.25rem;"></div>
            <!-- Extracted Text -->
            <div class="text-result-section">
              <div class="text-result-header">
                <h3 class="section-label">Extracted Text</h3>
                <span class="word-count" id="word-count"></span>
              </div>
              <div class="extracted-text" id="extracted-text"></div>
            </div>
            <!-- Confidence -->
            <div class="confidence-row">
              <span class="confidence-label">OCR Confidence</span>
              <div class="confidence-bar-wrap">
                <div class="progress-bar" style="height:6px">
                  <div class="progress-fill" id="confidence-fill" style="width:0%"></div>
                </div>
              </div>
              <span class="confidence-val" id="confidence-val">—</span>
            </div>
          </div>

          <!-- Error State -->
          <div class="error-state" id="error-state" style="display:none">
            <p class="error-icon">⚠</p>
            <p class="error-msg" id="error-msg">Something went wrong.</p>
            <button class="btn btn-ghost btn-sm" id="retry-btn" type="button">Try again</button>
          </div>
        </div>

      </div>
    </div>
  </main>

  <!-- How It Works -->
  <section class="how-section">
    <div class="container">
      <h2 class="how-title animate-fade-up">How it works</h2>
      <div class="steps-grid">
        <div class="step animate-fade-up delay-1">
          <span class="step-num">01</span>
          <h3>Upload or Link</h3>
          <p>Drop an image file or paste a direct image URL into the tool.</p>
        </div>
        <div class="step animate-fade-up delay-2">
          <span class="step-num">02</span>
          <h3>OCR Processing</h3>
          <p>Tesseract.js runs entirely in your browser — no data leaves your device.</p>
        </div>
        <div class="step animate-fade-up delay-3">
          <span class="step-num">03</span>
          <h3>Read &amp; Identify</h3>
          <p>Get the extracted text and font trait analysis. Copy or download instantly.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="container footer-inner">
      <span class="footer-brand">FontScan</span>
      <span class="footer-note">Built with Astro · OCR by Tesseract.js · All processing is local</span>
    </div>
  </footer>
</Layout>

<script>
  import('../scripts/extractor.js');
</script>

<style>
/* ── Header ── */
.site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  padding-block: 1.1rem;
  background: rgba(10, 9, 6, 0.85);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--smoke-2);
}
.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
}
.logo {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  cursor: default;
}
.logo-mark {
  width: 32px; height: 32px;
  background: var(--amber);
  color: var(--ink);
  font-family: var(--font-display);
  font-weight: 900;
  font-size: 1.1rem;
  display: grid;
  place-items: center;
  border-radius: 4px;
}
.logo-text {
  font-family: var(--font-display);
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--cream);
  letter-spacing: -0.02em;
}
.nav-links {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
  justify-content: flex-end;
}

/* ── Hero ── */
.hero {
  position: relative;
  padding-block: clamp(5rem, 12vw, 9rem) clamp(3rem, 6vw, 5rem);
  overflow: hidden;
}
.hero-blob-1 {
  width: 600px; height: 600px;
  background: radial-gradient(circle, rgba(232,168,51,0.18) 0%, transparent 70%);
  top: -200px; left: -150px;
}
.hero-blob-2 {
  width: 400px; height: 400px;
  background: radial-gradient(circle, rgba(232,168,51,0.08) 0%, transparent 70%);
  bottom: 0; right: 10%;
}
.hero-content { position: relative; z-index: 1; max-width: 750px; }
.hero-eyebrow {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 1.75rem;
}
.eyebrow-line {
  display: block;
  width: 40px; height: 1px;
  background: var(--amber);
}
.hero-title {
  color: var(--cream);
  letter-spacing: -0.03em;
  margin-bottom: 1.5rem;
}
.hero-title em {
  font-style: italic;
  color: var(--amber);
}
.hero-subtitle {
  font-size: clamp(0.9rem, 1.5vw, 1.05rem);
  color: var(--cream-dim);
  max-width: 520px;
  opacity: 0.85;
}
.hero-type-strip {
  margin-top: 4rem;
  overflow: hidden;
  border-top: 1px solid var(--smoke-2);
  border-bottom: 1px solid var(--smoke-2);
  padding-block: 0.75rem;
}
.type-scroll-inner {
  display: flex;
  gap: 4rem;
  white-space: nowrap;
  font-family: var(--font-display);
  font-size: clamp(1rem, 2.5vw, 1.5rem);
  color: var(--cream-dim);
  opacity: 0.35;
  animation: marquee 30s linear infinite;
  letter-spacing: 0.15em;
}
@keyframes marquee {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}

/* ── Tool Section ── */
.tool-section {
  padding-block: clamp(3rem, 8vw, 6rem);
}
.tool-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
  align-items: start;
}
@media (max-width: 900px) {
  .tool-grid { grid-template-columns: 1fr; }
}

/* ── Panel ── */
.input-panel, .results-panel {
  padding: 2rem;
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}
.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.panel-title {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--amber);
  font-style: normal;
}
.panel-dots {
  display: flex; gap: 6px;
}
.panel-dots span {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--smoke-3);
}
.panel-dots span:first-child { background: var(--amber-dim); opacity: 0.5; }

/* ── Upload Zone ── */
.upload-zone {
  border: 1.5px dashed var(--smoke-3);
  border-radius: var(--radius-md);
  padding: 2.5rem 1.5rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.75rem;
  text-align: center;
  transition: border-color 0.25s, background 0.25s;
  cursor: pointer;
  position: relative;
}
.upload-zone:hover, .upload-zone.drag-over {
  border-color: var(--amber-dim);
  background: var(--amber-glow);
}
.upload-icon {
  color: var(--amber-dim);
  opacity: 0.7;
  transition: transform 0.3s var(--ease-out-expo), opacity 0.3s;
}
.upload-zone:hover .upload-icon {
  transform: translateY(-4px);
  opacity: 1;
}
.upload-label {
  font-family: var(--font-display);
  font-size: 1.1rem;
  color: var(--cream);
}
.upload-sub {
  font-size: 0.72rem;
  color: var(--cream-dim);
  opacity: 0.5;
  letter-spacing: 0.06em;
}

/* ── OR Divider ── */
.or-divider {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}
.or-label {
  font-size: 0.72rem;
  color: var(--cream-dim);
  opacity: 0.5;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  white-space: nowrap;
}

/* ── URL Row ── */
.input-label {
  display: block;
  font-size: 0.72rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--cream-dim);
  margin-bottom: 0.5rem;
  opacity: 0.7;
}
.url-row {
  display: flex;
  gap: 0.5rem;
}
.url-row .input { flex: 1; }

/* ── Preview ── */
.preview-area {
  position: relative;
  border-radius: var(--radius-md);
  overflow: hidden;
  border: 1px solid var(--smoke-2);
}
.preview-img {
  width: 100%;
  max-height: 240px;
  object-fit: contain;
  display: block;
  background: var(--ink-2);
}
.clear-btn {
  position: absolute;
  top: 8px; right: 8px;
  width: 28px; height: 28px;
  border-radius: 50%;
  border: none;
  background: rgba(10,9,6,0.8);
  color: var(--cream);
  font-size: 0.75rem;
  cursor: pointer;
  display: grid;
  place-items: center;
  transition: background 0.2s;
}
.clear-btn:hover { background: var(--amber); color: var(--ink); }

/* ── Extract Button ── */
.extract-btn {
  width: 100%;
  justify-content: center;
  padding-block: 1rem;
  font-size: 0.85rem;
}
.btn-icon { font-size: 1rem; }

/* ── Progress ── */
.progress-wrap {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.progress-label {
  font-size: 0.72rem;
  color: var(--amber);
  letter-spacing: 0.06em;
}

/* ── Empty State ── */
.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 1.5rem;
  padding: 3rem 1rem;
}
.empty-grid {
  display: flex;
  gap: 0.5rem;
}
.empty-letter {
  font-family: var(--font-display);
  font-size: clamp(1.5rem, 3vw, 2rem);
  color: var(--cream-dim);
  opacity: 0;
  animation: fadeUp 0.6s var(--ease-out-expo) calc(var(--d) * 0.1s) both;
  filter: blur(0);
  animation-iteration-count: 1;
}
.empty-label {
  font-size: 0.8rem;
  color: var(--cream-dim);
  opacity: 0.45;
  text-align: center;
}

/* ── Results Content ── */
.results-content { display: flex; flex-direction: column; }
.section-label {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--amber);
  font-weight: 500;
  margin-bottom: 0.75rem;
  font-style: normal;
}
.font-traits {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}
.trait-chip {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.35rem 0.85rem;
  background: var(--ink-2);
  border: 1px solid var(--smoke-2);
  border-radius: 3px;
  font-size: 0.75rem;
  color: var(--cream-dim);
  transition: border-color 0.2s, color 0.2s;
}
.trait-chip:hover { border-color: var(--amber-dim); color: var(--cream); }
.trait-chip .chip-key {
  color: var(--amber);
  font-size: 0.65rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.text-result-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 0.75rem;
}
.word-count {
  font-size: 0.7rem;
  color: var(--cream-dim);
  opacity: 0.6;
}
.extracted-text {
  background: var(--ink-2);
  border: 1px solid var(--smoke-2);
  border-radius: var(--radius-sm);
  padding: 1rem 1.25rem;
  font-family: var(--font-mono);
  font-size: 0.82rem;
  color: var(--cream);
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-word;
  max-height: 300px;
  overflow-y: auto;
  margin-bottom: 1.25rem;
}
.confidence-row {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  font-size: 0.72rem;
}
.confidence-label {
  color: var(--cream-dim);
  opacity: 0.6;
  white-space: nowrap;
  letter-spacing: 0.06em;
}
.confidence-bar-wrap { flex: 1; }
.confidence-val {
  color: var(--amber);
  font-weight: 500;
  white-space: nowrap;
  min-width: 3.5ch;
  text-align: right;
}
.panel-actions { display: flex; gap: 0.5rem; }
.btn-sm { padding: 0.45rem 1rem; font-size: 0.72rem; }

/* ── Error ── */
.error-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 0.75rem;
  padding: 3rem 1rem;
  text-align: center;
}
.error-icon { font-size: 2rem; color: #e07850; }
.error-msg { font-size: 0.85rem; color: var(--cream-dim); }

/* ── How It Works ── */
.how-section {
  padding-block: clamp(4rem, 10vw, 8rem);
  border-top: 1px solid var(--smoke-2);
}
.how-title {
  text-align: center;
  margin-bottom: 3.5rem;
  color: var(--cream);
  letter-spacing: -0.02em;
}
.steps-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 1.5rem;
}
.step {
  padding: 2rem;
  background: var(--ink-3);
  border: 1px solid var(--smoke-2);
  border-radius: var(--radius-lg);
  transition: border-color 0.3s, transform 0.3s var(--ease-out-expo);
}
.step:hover {
  border-color: var(--amber-dim);
  transform: translateY(-4px);
}
.step-num {
  display: block;
  font-size: 0.7rem;
  letter-spacing: 0.15em;
  color: var(--amber);
  margin-bottom: 1rem;
}
.step h3 {
  font-family: var(--font-display);
  font-size: 1.2rem;
  color: var(--cream);
  margin-bottom: 0.5rem;
}
.step p {
  font-size: 0.82rem;
  color: var(--cream-dim);
  opacity: 0.7;
  line-height: 1.7;
}

/* ── Footer ── */
.site-footer {
  border-top: 1px solid var(--smoke-2);
  padding-block: 2rem;
}
.footer-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  flex-wrap: wrap;
}
.footer-brand {
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 700;
  color: var(--amber);
}
.footer-note {
  font-size: 0.72rem;
  color: var(--cream-dim);
  opacity: 0.45;
}
</style>
